# Public URL of the backend server deployed on Render.
# The client routes all API, auth, and realtime (WebSocket/SSE) traffic here.
#
# Example (production):
#   VITE_API_URL=https://openchamber-backend.onrender.com
#
# Leave unset for local development — the Vite dev server proxies /api, /auth,
# and /health to http://127.0.0.1:3001 (see web/vite.config.ts).
VITE_API_URL=
