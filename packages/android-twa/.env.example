# OpenChamber TWA Configuration
# Copy to .env and fill in your values

# ── Build-time (Bubblewrap / Gradle) ──

# Required: Full URL to your OpenChamber web manifest
TWA_MANIFEST_URL=https://your-domain.com/site.webmanifest

# Required: Your domain hostname (without https://)
TWA_HOST=your-domain.com

# Optional: Android package ID (default: ai.opencode.openchamber.twa)
TWA_PACKAGE_ID=ai.opencode.openchamber.twa

# Optional: Path to existing keystore (leave empty to generate new)
TWA_KEYSTORE_PATH=

# Optional: Keystore key alias (default: openchamber)
TWA_KEY_ALIAS=openchamber

# Optional: For CI/CD builds, provide keystore password
BUBBLEWRAP_KEYSTORE_PASSWORD=

# ── Server-side (Digital Asset Links verification) ──
# These must be set on the OpenChamber web server to serve
# /.well-known/assetlinks.json, which removes the browser
# identity bar in the TWA Android app.

# Required: SHA-256 fingerprint of the APK signing certificate
# Generate with: keytool -list -v -keystore <keystore> -alias <alias>
TWA_SHA256_FINGERPRINT=

# Required: Android package name matching the APK's package_name
TWA_PACKAGE_NAME=
