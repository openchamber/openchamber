# ── Backend server configuration ─────────────────────────────────────────────

# Bind host. On Render (and other PaaS) this MUST be 0.0.0.0 so the platform
# can route external traffic to the container.
OPENCHAMBER_HOST=0.0.0.0

# Listen port. Render injects PORT automatically; the server honors it.
# For local runs you can set OPENCHAMBER_PORT instead (takes precedence).
# PORT=3001
# OPENCHAMBER_PORT=3001

# Password gate for the API when exposed on a public/network host.
# REQUIRED when OPENCHAMBER_HOST is 0.0.0.0 — the server refuses to expose an
# unauthenticated instance to the network.
OPENCHAMBER_UI_PASSWORD=change-me

# Public URL of the deployed CLIENT (used for CORS allow-listing).
# e.g. https://openchamber-client.vercel.app
OPENCHAMBER_CLIENT_URL=

# Run without serving any frontend assets (this backend is API-only).
OPENCHAMBER_API_ONLY=1

# ── Daytona sandbox orchestration ────────────────────────────────────────────
# Each chat session spins up an isolated Daytona sandbox running OpenCode.
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io
DAYTONA_SANDBOX_IMAGE=daytonaio/ai-opencode:latest
DAYTONA_SANDBOX_TIMEOUT_MS=600000
DAYTONA_OPENCODE_PORT=4096
